# Server
PORT=8080
JWT_SECRET=change-this-long-random-secret
MIGRATION_KEY=change-this-local-migration-key

# MongoDB
# Leave MONGO_URI empty and set MOPER_USE_MEMORY=true for local portfolio demo mode.
MONGO_URI=
MOPER_USE_MEMORY=true

# Default workplace seed
DEFAULT_WORKPLACE_NAME=Moper HQ
DEFAULT_WORKPLACE_LAT=40.9862
DEFAULT_WORKPLACE_LNG=29.1244
DEFAULT_WORKPLACE_RADIUS_METERS=250
DEFAULT_QR_TOKEN=MOPER_DEMO_QR
